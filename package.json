{
  "name": "eventpass-ton",
  "version": "0.1.0",
  "description": "Cross-chain event ticketing as Soulbound Tokens on TON blockchain",
  "private": true,
  "license": "MIT",
  "workspaces": [
    "backend/*",
    "mini-app",
    "bot",
    "contracts"
  ],
  "scripts": {
    "dev:backend": "cd backend/api-gateway && npm run start:dev",
    "dev:miniapp": "cd mini-app && npm run dev",
    "dev:bot": "cd bot && npm run dev",
    "build:all": "npm run build --workspaces",
    "lint:all": "npm run lint --workspaces",
    "test:all": "npm run test --workspaces"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}