# ============================================
# EventPass TON — Environment Variables
# ============================================

# TON Blockchain
TON_NETWORK=testnet
TON_ENDPOINT=https://testnet.toncenter.com/api/v2/
TON_API_KEY=
TON_MNEMONIC=

# STON.fi
STONFI_ROUTER_V2=
STONFI_API_URL=https://api.ston.fi

# Omniston
OMNISTON_WS_ENDPOINT=wss://omniston.ston.fi/ws
OMNISTON_GRPC_ENDPOINT=

# TON Connect
TONCONNECT_MANIFEST_URL=https://eventpass.ton/tonconnect-manifest.json

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
DATABASE_URL=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_MINI_APP_URL=

# GitHub
GITHUB_TOKEN=

# Sentry
SENTRY_DSN=

# Cross-chain RPCs
ETHEREUM_RPC_URL=
POLYGON_RPC_URL=
BNB_RPC_URL=
